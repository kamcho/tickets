# ==============================================================================
# Django Configuration Template (.env.example)
# ==============================================================================
# Copy this file to '.env' and modify the values for your environment.
# DO NOT commit the actual '.env' file containing real secrets to version control.

# Core Settings
# ------------------------------------------------------------------------------
# A secret, unique key for this particular installation.
# You can generate one using: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=django-insecure-w!6pye!qhw01mevr77v1(5cmwobbtn#pit9+xl0+0k-4np7z3+

# Enable/disable Django debug mode. (True for local development, False for production)
DEBUG=True

# Comma-separated list of domain names/IP addresses this site can serve.
# Example: 127.0.0.1,localhost,yourdomain.co.za,yourdomain.co.ke
ALLOWED_HOSTS=127.0.0.1,localhost


# Database Configuration
# ------------------------------------------------------------------------------
# Choose engine: 'sqlite3', 'mysql', or 'postgresql'
DB_ENGINE=sqlite3

# The name of the database. For SQLite, this is the filename (e.g. db.sqlite3).
# For MySQL or PostgreSQL, this is the database name created on your server.
DB_NAME=db.sqlite3

# Credentials for MySQL or PostgreSQL (Not needed for SQLite)
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306


# Production Security Headers (SSL)
# ------------------------------------------------------------------------------
# Set to 'True' in production to enforce HTTPS redirects and cookie security.
# (Make sure SSL is fully installed and working on HostAfrica before enabling these)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
