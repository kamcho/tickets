
SECRET_KEY=your-django-secret-key

DEBUG=True
# Set DEBUG=False in production. Run: python manage.py collectstatic
# WHITENOISE_USE_FINDERS=True  # optional: serve static without collectstatic (dev only)
ALLOWED_HOSTS=127.0.0.1,localhost,tickets.metrolinkssolutionltd.co.ke,metrolinkssolutionltd.co.ke,.ngrok-free.dev,.ngrok-free.app

CSRF_TRUSTED_ORIGINS=https://*.ngrok-free.dev,https://*.ngrok-free.app

TICKETS_PORTAL_LOGIN_URL=
# Base URL for ticket links in SMS (no browser request). Unset in DEBUG uses http://127.0.0.1:8000
# SITE_BASE_URL=https://tickets.metrolinkssolutionltd.co.ke

DB_ENGINE=sqlite3
DB_NAME=db.sqlite3
# For MySQL on cPanel set DB_ENGINE=mysql and run: python manage.py ensure_utf8mb4
# (emoji in AI chat requires utf8mb4 — utf8 alone causes OperationalError 1366)

# --- AI Assistant (OpenAI infers intent + picks tools; required for web/WhatsApp bot) ---

# OPENAI_BASE_URL=https://api.openai.com/v1
# ASSISTANT_MAX_HISTORY=24

# WhatsApp Cloud API (Meta Business) — same assistant tools as web
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=choose-a-random-verify-string
# wa.me link uses this if set; otherwise primary office phone below
WHATSAPP_DISPLAY_NUMBER=254792929275

# Office contact (footer & landing)
COMPANY_PHONE_PRIMARY=0792929275
COMPANY_PHONE_SECONDARY=0746464696
COMPANY_EMAIL=metrolinkssolutionltd@gmail.com
# WHATSAPP_API_VERSION=v21.0

# --- UjumbeSMS (SMS when a ticket is created or assigned) ---
# Register at https://www.ujumbesms.co.ke/ — use portal email + API key from dashboard
# API expects numbers as 254712345678 (no +). Local 07... is converted automatically at send time.
UJUMBE_SMS_API_KEY=
UJUMBE_SMS_EMAIL=
# UJUMBE_SMS_SENDER_ID=UjumbeSMS
# UJUMBE_SMS_BASE_URL=https://ujumbesms.co.ke
# UJUMBE_SMS_ENABLED=True
# SMS_DEBUG_PRINT=True
